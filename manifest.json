{
  "manifest_version": 3,
  "name": "HH.ru Resume Free Up",
  "version": "2.0.9",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "https://*.hh.ru/*"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}